# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions


# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local working-memory / continuity docs (keep on disk, do not commit)
docs/PROJECT_CONTEXT.md
docs/ROADMAP.md
docs/DECISIONS.md
docs/TASTE_SKILL.md

# Local collaboration notes (keep on disk, do not commit)
AGENTS.md
CLAUDE.md

# raw screenshot sources before WebP optimize (keep structure + README)
/raw-quiz-images/**
!/raw-quiz-images/README.md
!/raw-quiz-images/**/.gitkeep

# Local media uploads (STORAGE_PROVIDER=local-public) — do not commit runtime files
/public/media/**
!/public/media/.gitkeep

