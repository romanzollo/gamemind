# Copy to .env / .env.local for local dev. Never commit real secrets.
# On Vercel: Project → Settings → Environment Variables (Production).

# --- Database (Neon) ---
# Pooled connection for Prisma + quiz JSONB snapshot insert (has -pooler).
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
DATABASE_URL=

# Direct (unpooled) for quiz/admin critical pg paths and migrations/seed.
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Do NOT paste the same string into both variables.
DATABASE_URL_UNPOOLED=

# Optional: production Neon URLs for one-off migrate scripts (never point local
# DATABASE_URL at prod permanently). Example:
# node scripts/apply-named-migration.cjs <name> PROD_DATABASE_URL_UNPOOLED
# PROD_DATABASE_URL=
# PROD_DATABASE_URL_UNPOOLED=

# --- Auth.js / NextAuth v5 ---
# Generate: openssl rand -base64 32
# Required in production.
AUTH_SECRET=

# Public site origin (no trailing slash).
# Local:  http://localhost:3000
# After first Vercel deploy: https://your-app.vercel.app
# After custom domain:       https://your-domain.com
AUTH_URL=

# Optional alias some setups still read; keep equal to AUTH_URL if set.
# NEXTAUTH_URL=