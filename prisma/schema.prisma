generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  role          Role      @default(USER)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  quizSessions QuizSession[]
  quizResults  QuizResult[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Question {
  id         String     @id @default(cuid())
  text       String
  difficulty Difficulty
  category   String     @default("video-games")
  metadata   Json?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  options     AnswerOption[]
  quizAnswers QuizAnswer[]
  sessionQuestions QuizSessionQuestion[]

  @@index([difficulty, isActive])
}

model AnswerOption {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  quizAnswers QuizAnswer[]
  sessionQuestionOptions QuizSessionQuestionOption[]

  @@index([questionId])
}

model QuizSession {
  id            String            @id @default(cuid())
  userId        String
  status        QuizSessionStatus @default(IN_PROGRESS)
  difficulty    Difficulty
  questionCount Int
  startedAt     DateTime          @default(now())
  completedAt   DateTime?

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]
  result  QuizResult?
  sessionQuestions QuizSessionQuestion[]

  @@index([userId, status])
}

model QuizAnswer {
  id               String   @id @default(cuid())
  sessionId        String
  questionId       String
  selectedOptionId String
  isCorrect        Boolean
  answeredAt       DateTime @default(now())

  session        QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question       Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption AnswerOption @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([sessionId])
}

model QuizResult {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  userId         String
  score          Int
  totalQuestions Int
  correctCount   Int
  completedAt    DateTime @default(now())

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([score(sort: Desc), completedAt(sort: Asc)])
}

model QuizSessionQuestion {
  id         String @id @default(cuid())
  sessionId  String
  questionId String
  position   Int

  session  QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  options  QuizSessionQuestionOption[]

  @@unique([sessionId, questionId])
  @@unique([sessionId, position])
  @@index([sessionId])
}

model QuizSessionQuestionOption {
  id                String @id @default(cuid())
  sessionQuestionId String
  optionId          String
  displayOrder      Int

  sessionQuestion QuizSessionQuestion @relation(fields: [sessionQuestionId], references: [id], onDelete: Cascade)
  option          AnswerOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([sessionQuestionId, optionId])
  @@unique([sessionQuestionId, displayOrder])
  @@index([sessionQuestionId])
}
